# ============================================
# Stellar Network Configuration
# ============================================

# The network to operate on: 'testnet' (default) or 'mainnet'
STELLAR_NETWORK=testnet

# Testnet Configuration
STELLAR_PUBLIC_KEY=GTEST...
STELLAR_PRIVATE_KEY=STEST...
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Legacy alias if needed: SRB_PROVIDER_URL=https://soroban-testnet.stellar.org

# Mainnet Configuration (Uncomment and replace to use mainnet)
# STELLAR_NETWORK=mainnet
# STELLAR_PUBLIC_KEY=GMAIN...
# STELLAR_PRIVATE_KEY=SMAIN...
# SOROBAN_RPC_URL=https://soroban-mainnet.stellar.org

# ============================================
# Bridge Mainnet Safeguard
# ============================================

# ⚠️ Required for mainnet bridging
# Set to 'true' to enable bridge operations on mainnet
# WARNING: Bridge transactions are irreversible
# ALLOW_MAINNET_BRIDGE=true

# ============================================
# EVM Configuration
# ============================================

# Destination chain configuration (optional)
# ETH_PUBLIC_KEY=0x...
# ETH_PRIVATE_KEY=...