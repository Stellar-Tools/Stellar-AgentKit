# ============================================
# Stellar Network Configuration
# ============================================

# Testnet Configuration (default)
STELLAR_PUBLIC_KEY=GTEST...
STELLAR_PRIVATE_KEY=STEST...
SRB_PROVIDER_URL=https://soroban-testnet.stellar.org

# Mainnet Configuration
# Uncomment these when using mainnet
# STELLAR_PUBLIC_KEY=GMAIN...
# STELLAR_PRIVATE_KEY=SMAIN...
# SRB_PROVIDER_URL=https://soroban.stellar.org

# ============================================
# Mainnet Safeguards
# ============================================

# ⚠️ Required for mainnet bridging
# Set to 'true' to enable bridge operations on mainnet
# WARNING: Bridge transactions are irreversible
# ALLOW_MAINNET_BRIDGE=true

# ⚠️ Required for mainnet asset management
# Set to 'true' to enable asset management operations on mainnet
# (create_asset, manage_trustline)
# WARNING: Asset operations on mainnet use real funds
# ALLOW_MAINNET_ASSET_MANAGEMENT=true

# ============================================
# EVM Configuration
# ============================================

# Destination chain configuration (optional)
# ETH_PUBLIC_KEY=0x...
# ETH_PRIVATE_KEY=...